# Used by docker-compose. Copy to `.env` and fill in.
#
#   cp .env.example .env

# Google Gemini API key — only needed for the "Analyze with AI" button.
# The deterministic "Analyze" button works without it.
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Gemini model for AI analysis (default gemini-2.5-flash).
GEMINI_MODEL=gemini-2.5-flash
