{
  "manifest_version": 3,
  "name": "InspectFlow",
  "version": "0.2.0",
  "description": "Sync Chrome DevTools CSS changes back to your React/Next.js source with approval-gated AI edits.",
  "minimum_chrome_version": "116",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "InspectFlow",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  "devtools_page": "devtools.html",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
