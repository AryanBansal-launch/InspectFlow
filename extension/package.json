{
  "name": "inspectflow-extension",
  "version": "0.2.0",
  "private": true,
  "description": "InspectFlow Chrome extension (Manifest V3) — capture DevTools CSS changes and drive approval-gated source edits.",
  "type": "module",
  "scripts": {
    "icons": "node scripts/generate-icons.mjs",
    "build": "node build.mjs",
    "dev": "node build.mjs --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.287",
    "esbuild": "^0.24.2",
    "typescript": "^5.7.3"
  }
}
