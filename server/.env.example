# ----------------------------------------------------------------------------
# InspectFlow MCP Server — environment configuration
# Copy this file to `.env` and fill in the values.
# ----------------------------------------------------------------------------

# Google Gemini API key used to translate CSS changes into source edits.
# Required for the analysis features (Phase 5+). The server boots without it,
# but analysis endpoints/tools will report that the key is missing.
# Get one at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Gemini model used for analysis. Defaults to gemini-2.5-flash.
GEMINI_MODEL=gemini-2.5-flash

# HTTP port the Express + MCP server listens on.
PORT=4399

# Host/interface to bind. Use 127.0.0.1 to stay local-only (recommended).
HOST=127.0.0.1

# Absolute path to the project whose source files may be edited.
# All file writes are sandboxed to this directory. Path traversal is rejected.
# Defaults to the current working directory if unset.
PROJECT_ROOT=

# Log level: trace | debug | info | warn | error | fatal | silent
LOG_LEVEL=info

# Pretty-print logs (true for local dev, false for JSON logs in production).
LOG_PRETTY=true

# Comma-separated list of allowed CORS origins for the HTTP API.
# The Chrome extension and DevTools panels connect from these origins.
# Use "*" to allow any origin (convenient for local dev only).
CORS_ORIGINS=*
